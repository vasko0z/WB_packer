root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false
indent_size = 2

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.{sh,bash}]
end_of_line = lf

[*.ps1]
end_of_line = crlf

[Makefile]
indent_style = tab

[*.{ts,js,tsx,jsx}]
indent_size = 2
quote_type = single

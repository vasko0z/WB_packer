API_PORT=${API_PORT:-8000}
API_KEYS=${API_KEYS:-dev-key-change-me}
CORS_ORIGINS=${CORS_ORIGINS:-*}

# Google Sheets (service account JSON, base64 or file path)
GSHEETS_CREDENTIALS=${GSHEETS_CREDENTIALS:-}
GSHEETS_SPREADSHEET_ID=${GSHEETS_SPREADSHEET_ID:-1OGgsS0T4qaEekJgEkVTplZfoeQ7MeMth8o8eJTqnJGA}
GSHEETS_SKU_SPREADSHEET_ID=${GSHEETS_SKU_SPREADSHEET_ID:-1tQzh_qTnldbpeu9ryNF8ZKY4-amwT8UfuMqbSU1qOlA}

# Moysklad
